# Copy this file to `.env` and set real values. `docker compose` reads `.env`
# automatically, so these apply to docker-compose.dist.yml with no extra flags.
# `.env` is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED for docker-compose.dist.yml — used by BOTH the postgres container and
# the backend's connection string. There is no default; the stack won't start
# without it. Generate a strong one, e.g.:
#   echo "BOUNDFLOW_DB_PASSWORD=$(openssl rand -hex 16)" >> .env
BOUNDFLOW_DB_PASSWORD=

# Bring your own database (recommended for production): point the backend at a
# managed Postgres (RDS / Cloud SQL / Azure DB) and stop relying on the bundled
# `postgres` service. Always use TLS — sslmode=require. When set, this overrides
# the bundled URL above entirely.
# BOUNDFLOW_DATABASE_URL=postgres://user:password@your-db-host:5432/boundflow?sslmode=require

# ── Image ─────────────────────────────────────────────────────────────────────
# Pin a released version instead of :latest.
# BOUNDFLOW_IMAGE=ghcr.io/boundflow/boundflow:v0.1.0
